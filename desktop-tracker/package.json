{
  "name": "fluidhr-desktop-tracker",
  "version": "1.0.0",
  "description": "Premium Time Tracking Node for FluidHR",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-packager . FluidHR-Tracker --platform=win32 --arch=x64 --out=dist --overwrite"
  },
  "build": {
    "appId": "com.fluidhr.tracker",
    "productName": "FluidHR Tracker",
    "win": {
      "target": "portable",
      "icon": "icon.ico"
    }
  },
  "dependencies": {
    "axios": "^1.6.7",
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^28.2.4",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2"
  }
}

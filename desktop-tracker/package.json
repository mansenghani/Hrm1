{
  "name": "fluidhr-desktop-tracker",
  "version": "1.0.6",
  "description": "Premium Time Tracking Node for FluidHR",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "publish": "electron-builder --win --x64 --publish always"
  },
  "build": {
    "appId": "com.fluidhr.tracker",
    "productName": "FluidHR Tracker",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    },
    "publish": {
      "provider": "github",
      "owner": "mansenghani",
      "repo": "Hrm1"
    }
  },
  "dependencies": {
    "axios": "^1.6.7",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.9",
    "screenshot-desktop": "^1.15.4"
  },
  "devDependencies": {
    "electron": "^28.2.4",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2"
  }
}